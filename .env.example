# Copy this file to .env in the project root and fill only the services you use.
# .env is ignored by Git. Do not commit real secrets.

# MinerU token, when required by the selected profile.
MINERU_TOKEN=

# MinerU API host override, when required by the selected profile.
MINERU_BASE_URL=

# MinerU FastAPI profile values, when that profile is selected.
MINERU_FASTAPI_BASE_URL=
MINERU_FASTAPI_TOKEN=
MINERU_FASTAPI_SERVER_URL=
MINERU_FASTAPI_USER_AGENT=

# Optional MarkItDown OCR or OpenAI-compatible backend.
OPENAI_API_KEY=
MARKITDOWN_OCR_MODEL=
